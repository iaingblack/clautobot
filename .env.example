# Octopus Deploy (credentials only — space/project/runbook/environment are in workflows.yml)
OCTOPUS_SERVER_URL=http://localhost:8080
OCTOPUS_API_KEY=API-XXXXXXXXXXXX

# Jira Cloud (credentials only — project/status are in workflows.yml)
JIRA_BASE_URL=https://yoursite.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token

# Poller
POLL_INTERVAL_SECONDS=30
WEB_PORT=3000
